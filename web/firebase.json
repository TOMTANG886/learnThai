{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": true,
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Document-Policy",
            "value": "js-profiling"
          }
        ]
      }
    ]
  }
}
