{
  "name": "learn-thai-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:sheets": "tsx scripts/build-from-sheets.ts",
    "build:sheets:with-audio": "tsx scripts/build-from-sheets.ts --generate-audio",
    "build": "npm run build:sheets && next build",
    "build:with-audio": "npm run build:sheets:with-audio && next build",
    "deploy": "npm run build && firebase deploy --only hosting",
    "dev": "next dev",
    "start": "next start",
    "preview": "npm run build && next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "googleapis": "^128.0.0",
    "gray-matter": "^4.0.3",
    "next": "^13.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^13.5.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
