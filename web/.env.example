# Google Sheets — required
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_PATH=./credential.json

# Firebase deploy token (for CI)
FIREBASE_TOKEN=

# TTS Audio Generation — optional (defaults to 'mock' for local dev)
# Provider options: mock | local-gtts | http
TTS_PROVIDER=mock

# HTTP TTS provider — required only when TTS_PROVIDER=http
TTS_API_URL=
TTS_API_KEY=

# Default TTS voice identifier (provider-specific, e.g. "th-TH-Standard-A" for Google Cloud TTS)
DEFAULT_TTS_VOICE=

# local-gtts provider — path to soundsGen.py (optional, auto-detected if omitted)
SOUNDS_GEN_PATH=

# Python binary to use for local-gtts provider (default: python)
PYTHON_BIN=python
